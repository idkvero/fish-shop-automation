Процедура ОбработкаПроведения(Отказ, РежимПроведения)		Движения.ОстаткиРыб.Записывать = Истина;		Для Каждого ТекСтрока Из Рыбы Цикл				Запрос = Новый Запрос;		Запрос.Текст = 			"ВЫБРАТЬ			|	ОстаткиРыбОстатки.КоличествоОстаток КАК КоличествоОстаток,			|	ОстаткиРыбОстатки.СуммаОстаток КАК СуммаОстаток			|ИЗ			|	РегистрНакопления.ОстаткиРыб.Остатки(&Период, Аквариум = &Аквариум И ПородаРыб = &ПородаРыб) КАК ОстаткиРыбОстатки";				Запрос.УстановитьПараметр("Период", МоментВремени());		Запрос.УстановитьПараметр("Аквариум", ТекСтрока.Аквариум);		Запрос.УстановитьПараметр("ПородаРыб", ТекСтрока.ПородаРыб);				РезультатЗапроса = Запрос.Выполнить();				ОстатокКоличество = 0;		ОстатокСумма = 0;				Если Не РезультатЗапроса.Пустой() Тогда			Выборка = РезультатЗапроса.Выбрать();			Выборка.Следующий();			ОстатокКоличество = Выборка.КоличествоОстаток;			ОстатокСумма  = Выборка.СуммаОстаток;		КонецЕсли;				Если ОстатокКоличество < ТекСтрока.Количество Тогда			Сообщить("Не хватает рыбы породе " + ТекСтрока.ПородаРыб + " в аквариуме " + ТекСтрока.Аквариум);			Сообщить("Требуется: " + ТекСтрока.Количество + ", В наличии: " + ОстатокКоличество);			Отказ = Истина;			Продолжить; 
		КонецЕсли;				Если ОстатокКоличество = ТекСтрока.Количество Тогда			СписываемаяСебестоимость = ОстатокСумма;		Иначе			СписываемаяСебестоимость = (ОстатокСумма / ОстатокКоличество) * ТекСтрока.Количество;		КонецЕсли;				НовоеДвижение = Движения.ОстаткиРыб.Добавить();		НовоеДвижение.ВидДвижения = ВидДвиженияНакопления.Расход; 	
		НовоеДвижение.Период = Дата;		НовоеДвижение.Аквариум = ТекСтрока.Аквариум;		НовоеДвижение.ПородаРыб = ТекСтрока.ПородаРыб;				НовоеДвижение.Количество = ТекСтрока.Количество;        
		НовоеДвижение.Сумма  = СписываемаяСебестоимость;   			КонецЦикла;КонецПроцедуры